{
  "name": "humn-vscode",
  "displayName": "Humn",
  "version": "1.0.5",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KeeghanM/humn.git"
  },
  "scripts": {
    "build": "node scripts/build.cjs",
    "qa:test": "node scripts/validate-grammar.cjs",
    "package": "npx @vscode/vsce package",
    "vscode:prepublish": "npm run build"
  },
  "license": "MIT",
  "publisher": "HumanSideOfCode",
  "description": "Syntax highlighting and language support for the Humn language",
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onLanguage:humn",
    "onCommand:humn.toggleComment"
  ],
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "commands": [
      {
        "command": "humn.toggleComment",
        "title": "Humn: Toggle Comment"
      }
    ],
    "keybindings": [
      {
        "command": "humn.toggleComment",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "editorTextFocus && editorLangId == humn"
      }
    ],
    "grammars": [
      {
        "language": "humn",
        "scopeName": "source.humn",
        "path": "./syntaxes/humn.tmLanguage.json",
        "embeddedLanguages": {
          "text.html.basic": "html",
          "source.tsx.embedded.humn": "typescriptreact",
          "source.tsx": "typescriptreact",
          "source.ts": "typescript",
          "source.js": "javascript",
          "source.css": "css"
        }
      }
    ],
    "languages": [
      {
        "id": "humn",
        "aliases": [
          "Humn",
          "humn"
        ],
        "extensions": [
          ".humn"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/humn-light.svg",
          "dark": "./icons/humn-dark.svg"
        }
      }
    ],
    "snippets": [
      {
        "language": "humn",
        "path": "./snippets/humn.json"
      }
    ]
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "typescript": "^5.5.4",
    "semantic-release-vsce": "^6.0.18"
  },
  "dependencies": {
    "humn-language-server": "^0.0.0",
    "vscode-languageclient": "^9.0.1"
  }
}
