# Ignore source control and local tooling
.git
.gitignore
.vscode
.github
**/*.map
src/
scripts/
*.vsix

vite.config.js

# Runtime source and production dependencies are required by the extension.
node_modules/**/.bin
node_modules/**/.cache
node_modules/**/test
node_modules/**/tests
node_modules/**/__tests__

# Ignore the monorepo root references if any exist
../
../../
