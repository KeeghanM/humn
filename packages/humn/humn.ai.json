{
  "name": "humn",
  "type": "frontend-framework",
  "componentExtension": ".humn",
  "statePrimitive": "Cortex",
  "compiler": "vite-plugin-humn",
  "avoid": [
    "React hooks",
    "Svelte $: syntax",
    "Solid createSignal",
    "Vue composition API"
  ],
  "recommendedFiles": [
    "src/cortexes/*.js",
    "src/components/*.humn",
    "src/app/*.humn"
  ]
}
