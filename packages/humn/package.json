{
  "name": "humn",
  "version": "1.7.0",
  "description": "A minimal, human-centric reactive UI library with built in state management.",
  "keywords": [
    "reactive",
    "ui",
    "state",
    "cortex"
  ],
  "homepage": "https://www.npmjs.com/package/humn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KeeghanM/humn.git"
  },
  "license": "MIT",
  "author": "Keeghan McGarry",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/humn.js",
      "require": "./dist/humn.umd.js"
    }
  },
  "main": "./dist/humn.umd.js",
  "module": "./dist/humn.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "humn": "./bin/humn.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE",
    "llms.txt",
    "llms-full.txt",
    "AGENTS.md",
    "CLAUDE.md",
    ".cursor",
    "humn.ai.json"
  ],
  "scripts": {
    "bench": "node benchmarks/large-app.js",
    "build": "vite build && tsc -p tsconfig.json",
    "dev": "vite --port 3000 --open /playground/",
    "prepublishOnly": "npm run build",
    "qa:test": "vitest run",
    "qa:test:watch": "vitest watch"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@semantic-release/npm": "^13.1.2",
    "@types/node": "^24.10.1",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "jsdom": "^27.2.0",
    "semantic-release": "^25.0.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vite-plugin-humn": "*",
    "vitest": "^4.0.15"
  }
}
